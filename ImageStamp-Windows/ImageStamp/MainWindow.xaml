<Window
    x:Class="ImageStamp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ImageStamp"
    Title="ImageStamp"
    MinWidth="720"
    MinHeight="540">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Title bar -->
            <RowDefinition Height="*" />       <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── Title bar ── -->
        <Border Grid.Row="0"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo + name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center">
                    <Image Source="Assets/AppIcon.png" Width="32" Height="32"
                           CornerRadius="7" />
                    <TextBlock Text="ImageStamp"
                               FontSize="17" FontWeight="Bold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Date picker -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Date" VerticalAlignment="Center"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                    <CalendarDatePicker x:Name="DatePicker"
                                        PlaceholderText="Select date"
                                        DateChanged="DatePicker_DateChanged" />
                </StackPanel>

                <!-- Settings button -->
                <Button Grid.Column="2" x:Name="SettingsButton"
                        Style="{StaticResource TransparentButtonStyle}"
                        Click="SettingsButton_Click"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE713;" FontSize="18" />
                </Button>
            </Grid>
        </Border>

        <!-- ── Content area ── -->
        <Frame Grid.Row="1" x:Name="ContentFrame" />

    </Grid>
</Window>
