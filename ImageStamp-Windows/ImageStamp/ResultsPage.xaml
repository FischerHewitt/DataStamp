<Page
    x:Class="ImageStamp.ResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ImageStamp"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Summary bar -->
            <RowDefinition Height="*" />     <!-- Results list -->
            <RowDefinition Height="Auto" />  <!-- Bottom bar -->
        </Grid.RowDefinitions>

        <!-- Summary bar -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" Spacing="20">
                <ProgressRing x:Name="ProcessingRing" IsActive="True" Width="20" Height="20" />
                <TextBlock x:Name="SummaryText" VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>
        </Border>

        <!-- Results list -->
        <ListView Grid.Row="1" x:Name="ResultsListView" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ResultViewModel">
                    <Grid Padding="4,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <FontIcon Grid.Column="0"
                                  Glyph="{x:Bind StatusIcon}"
                                  Foreground="{x:Bind StatusColor}"
                                  FontSize="18"
                                  VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind FileName}"
                                       FontSize="13" FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind Message}"
                                       FontSize="11"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Bottom bar -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="ShowFolderButton"
                        Content="Show in Explorer"
                        Style="{StaticResource TransparentButtonStyle}"
                        Click="ShowFolder_Click"
                        Visibility="Collapsed"
                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

                <Button Grid.Column="2"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="StartOver_Click"
                        Padding="20,8" CornerRadius="20">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock Text="Start Over" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
