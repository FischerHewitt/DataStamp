<Application
    x:Class="ImageStamp.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Brand colours -->
            <Color x:Key="BrandNavy">#0F2340</Color>
            <Color x:Key="BrandMid">#1E4F9E</Color>
            <Color x:Key="BrandAccent">#1A8CF2</Color>
            <Color x:Key="BrandLight">#BFE5FF</Color>

            <SolidColorBrush x:Key="BrandAccentBrush" Color="{StaticResource BrandAccent}" />
            <SolidColorBrush x:Key="BrandNavyBrush"   Color="{StaticResource BrandNavy}" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
